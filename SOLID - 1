from dataclasses import dataclass
from abc import ABC, abstractmethod
 
@dataclass
class Order:
    id: str
    price: float
    qty: int
    customer_email: str
 
class OrderLoader:
    def load(self, json_path: str) -> list:
        with open(json_path, "r", encoding="utf-8") as f:
            return json.load(f)
 
class OrderParser:
    def parse(self, raw: list) -> list[Order]:
        orders = []
        for item in raw:
            if not all(k in item for k in ("id", "price", "qty", "email")):
                raise ValueError("Invalid order payload")
            if item["qty"] <= 0:
                raise ValueError("qty must be positive")
            orders.append(Order(item["id"], float(item["price"]),
                                int(item["qty"]), item["email"]))
        return orders
 
class TotalCalculator:
    def total(self, orders: list[Order]) -> float:
        return sum(o.price * o.qty for o in orders)
 
class ReportFormatter:
    def format(self, orders: list[Order], total: float) -> str:
        return f"Orders count: {len(orders)}\nTotal: {total:.2f}\n"
 
class Sender(ABC):
    @abstractmethod
    def send(self, to: str, subject: str, body: str) -> None: ...
 
class EmailSender(Sender):
    def send(self, to, subject, body) -> None:
        print(f"[EMAIL to={to}] {subject}\n{body}")
 
class NullSender(Sender):
    def send(self, to, subject, body) -> None:
        pass
 
class OrderReportService:
    def __init__(self, loader=None, parser=None, calculator=None,
                 formatter=None, sender=None):
        self.loader = loader or OrderLoader()
        self.parser = parser or OrderParser()
        self.calculator = calculator or TotalCalculator()
        self.formatter = formatter or ReportFormatter()
        self.sender = sender or EmailSender()
 
    def make_and_send_report(self, json_path: str) -> str:
        raw = self.loader.load(json_path)
        orders = self.parser.parse(raw)
        total = self.calculator.total(orders)
        report = self.formatter.format(orders, total)
        for o in orders:
            self.sender.send(o.customer_email, "Your order report", report)
        return report
