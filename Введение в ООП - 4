class OddEvenSeparator:
    def __init__(self):
        self.evens = []
        self.odds = []

    def add_number(self, n):
        if n % 2 == 0:
            self.evens.append(n)
        else:
            self.odds.append(n)

    def even(self):
        return self.evens

    def odd(self):
        return self.odds
