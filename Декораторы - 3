ef check_password(password):
    def decorator(func):
        def wrapper(*args, **kwargs):
            entered = input("Введите пароль: ")
            if entered != password:
                print("В доступе отказано")
                return None
            return func(*args, **kwargs)
        return wrapper
    return decorator
 
 
