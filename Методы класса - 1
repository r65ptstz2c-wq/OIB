class Temperature:
    @staticmethod
    def c_to_f(c: float) -> float:
        return round(c * 9 / 5 + 32, 2)
 
    @staticmethod
    def f_to_c(f: float) -> float:
        return round((f - 32) * 5 / 9, 2)
Задача 2. Password
class Password:
    @staticmethod
    def is_strong(p: str) -> bool:
        return (
            len(p) >= 8
            and any(ch.isdigit() for ch in p)
            and any(ch.isupper() for ch in p)
            and any(ch.islower() for ch in p)
        )
Задача 3. User
class User:
    _count = 0
 
    def __init__(self, id: int, name: str):
        self.id = id
        self.name = name
 
    @classmethod
    def create(cls, name: str) -> "User":
        cls._count += 1
        return cls(cls._count, name)
 
    @classmethod
    def count(cls) -> int:
        return cls._count
