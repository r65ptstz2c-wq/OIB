class User:
    def __init__(self, name):
        self.name = name
 
    def send_message(self, user, message):
        print(f"{self.name} -> {user.name}: {message}")
 
    def post(self, message):
        print(f"{self.name} (на стене): {message}")
 
    def info(self):
        return ""
 
    def describe(self):
        print(self.name + self.info())
 
 
class Person(User):
    def __init__(self, name, birth_date):
        super().__init__(name)
        self.birth_date = birth_date
 
    def info(self):
        return " Дата рождения: " + str(self.birth_date)
 
    def subscribe(self, user):
        pass
 
 
class Community(User):
    def __init__(self, name, description):
        super().__init__(name)
        self.description = description
 
    def info(self):
        return " Описание: " + str(self.description)
